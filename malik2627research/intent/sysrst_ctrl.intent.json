{
  "ip_name": "sysrst_ctrl",
  "ip_intent": {
    "ip_name": "sysrst_ctrl",
    "one_line_desc": "Manages board-level reset sequencing, interfaces reset and power manager",
    "one_paragraph_desc": "System Reset Controller provides basic board-level reset sequencing in response to trusted inputs.\nIt is programmable to accommodate actions triggered by presses of buttons and keyboard key combinations, to control the duration of reset pulses, and to trigger reset or wake-up requests that go to Reset Manager and to Power Manager.\nSystem Reset Controller is part of the always-on power and clock domain.",
    "clocking": [
      {
        "clock": "clk_i",
        "reset": "rst_ni",
        "primary": true
      },
      {
        "clock": "clk_aon_i",
        "reset": "rst_aon_ni",
        "primary": false
      }
    ],
    "bus_interfaces": [
      {
        "protocol": "tlul",
        "direction": "device"
      }
    ],
    "param_list": [
      {
        "name": "NumCombo",
        "desc": "Number of keyboard combos",
        "default": "4"
      },
      {
        "name": "NumKeyIntr",
        "desc": "Number of keys that can trigger interrupts",
        "default": "7"
      },
      {
        "name": "TimerWidth",
        "desc": "Number of timer bits",
        "default": "16"
      },
      {
        "name": "DetTimerWidth",
        "desc": "Number of detection timer bits",
        "default": "32"
      }
    ],
    "interrupts": [
      {
        "intent_id": "sysrst_ctrl.interrupt.event_detected",
        "name": "event_detected",
        "desc": "Common interrupt triggered by combo or keyboard events."
      }
    ],
    "alerts": [
      {
        "intent_id": "sysrst_ctrl.alert.fatal_fault",
        "name": "fatal_fault",
        "desc": "This fatal alert is triggered when a fatal TL-UL bus integrity fault is detected."
      }
    ],
    "registers": [
      {
